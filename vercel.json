      "destination": "/the-lab.html",
      "permanent": true
    },

    {
      "source": "/contact",
      "destination": "/index.html#booking-form",
      "permanent": true
    },
    {
      "source": "/contact/",
      "destination": "/index.html#booking-form",
      "permanent": true
    },

    {
      "source": "/special-acts",
      "destination": "/the-elements.html",
      "permanent": true
    },
    {
      "source": "/special-acts/",
